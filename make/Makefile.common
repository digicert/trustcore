libmss: $(MSS_TARGET)
	$(CC) -shared -o $(BIN_DIR)$(SEP)libmss.so $(MSS_TARGET)

libmss_crypto: $(OPENSSL_MSS_TARGET)
	$(CC) -shared -o $(BIN_DIR)$(SEP)libmss.so $(OPENSSL_MSS_TARGET)

binlibs: libmss

# This target is only avai on vxworks
KBINLIBS = \
	$(LIB_DIR)$(SEP)libmss_ipsec.a \

kbinlibs: $(KBINLIBS)
	@echo $@ build complete

.PHONY: clean cleanobjs cleanbins clean_modules clean_vxtmp

# Add cleanlibs
clean: cleanobjs cleanbins clean_modules clean_vxtmp cleanlibs

cleanobjs:
	$(RM) $(OBJ_DIR)$(SEP)*.o $(LIB_DIR)$(SEP)*.a $(LIB_DIR)$(SEP)*.so
	$(RM) $(OBJ_DIR)$(SEP)*.omap $(OBJ_DIR)$(SEP)obfuscate.txt

cleanbins:
	$(RM) $(BIN_DIR)$(SEP)cmpc $(BIN_DIR)$(SEP)dtls[cs] $(BIN_DIR)$(SEP)ssh[cs] $(BIN_DIR)$(SEP)ssl[cs] $(BIN_DIR)$(SEP)eap* $(BIN_DIR)$(SEP)ike $(BIN_DIR)$(SEP)ikepfkey $(BIN_DIR)$(SEP)radc $(BIN_DIR)$(SEP)scepc $(BIN_DIR)$(SEP)syslogc $(BIN_DIR)$(SEP)ike_gdoi*
	$(RM) $(BIN_DIR)$(SEP)*.vxworks.* $(BIN_DIR)$(SEP)*.linux.*
	$(RM) $(BIN_DIR)$(SEP)*.o

clean_vxtmp:
	$(RM) src/examples/vxworks/*/*.o

# Clean static Libraries created for wpa2
cleanlibs:
	$(RM) $(LIB_DIR)/*.a

clean_modules:
ifeq "${MB_OS}" "linux"
ifneq ($(KDIR),)
ifneq ($(HW_ACCEL_DEV),)
	cd src/harness && $(MAKE) clean
endif
	cd src/harness/memdrv && $(MAKE) clean
	cd src/examples/ipsec/linux && $(MAKE) clean
	cd src/examples/ipsec_loadconfig && $(MAKE) cleanall
endif
endif
