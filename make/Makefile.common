else ifneq (,$(findstring __ENABLE_DIGICERT_TAP__,$(CFLAGS)))
ifneq (,$(findstring __ENABLE_DIGICERT_TAP_REMOTE__,$(CFLAGS)))
	$(LD) $(LIBS) -L$(BIN_DIR) -o $(BIN_DIR)$(SEP)$@$(OUT_EXT) $(SCEPC_TARGET) -lcryptointerface -lnanotap2 -lnanotap2_common -lsmptpm2 -ltpm2 -lnanossl -lnanocryptossl -lnanotap2_clientcomm -lnanotap2_configparser -lpthread -ldl
