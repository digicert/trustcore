	$(LD) $(LIBS) -L$(BIN_DIR) -o $(BIN_DIR)$(SEP)$@$(OUT_EXT) $(SCEPC_TARGET) -lcryptointerface -lnanotap2 -lnanotap2_common -lsmptpm2 -ltpm2 -lnanotap2_configparser -lpthread -ldl
endif
else
	$(LD) $(LIBS) -L$(BIN_DIR) -o $(BIN_DIR)$(SEP)$@$(OUT_EXT) $(SCEPC_TARGET)
endif
