ipsec: $(IPSEC_TARGET)
ifeq "${MB_OS}" "qnx"
	rm -f $@ $(LIB_DIR)$(SEP)libmss_ipsec.a
	${AR} $(LIB_DIR)$(SEP)libmss_ipsec.a ${IPSEC_TARGET}
ifneq ($(PLATFORM_TARGET_LIB_DIR),)
	cp $(LIB_DIR)$(SEP)libmss_ipsec.a "$(PLATFORM_TARGET_LIB_DIR)"
endif
else
	$(LD) $(LIBS) -o $(BIN_DIR)$(SEP)$@$(OUT_EXT) $(IPSEC_TARGET)
endif

# Use samples/nanosec if present, otherwise fall back to src/examples (ipsec)
ifeq ($(wildcard samples/nanosec),)
  NANOSEC_SRC     := src/examples
  NANOSEC_IPSEC   := src/examples/ipsec
  NANOSEC_LINUX   := src/examples/ipsec/linux
  NANOSEC_LOADCFG := src/examples/ipsec_loadconfig
else
  NANOSEC_SRC     := samples/nanosec/src
  NANOSEC_IPSEC   := samples/nanosec/src
  NANOSEC_LINUX   := samples/nanosec/src/linux
  NANOSEC_LOADCFG := samples/nanosec/src/ipsec_loadconfig
endif

ipsec_module:
	$(MAKE) -C $(NANOSEC_LINUX)/mocana -f ../Makefile.links.inc clean_links
	$(MAKE) -C $(NANOSEC_LINUX)/mocana -f ../Makefile.links.inc links
ifeq (${EXPORT},1)
	cd $(NANOSEC_LINUX) && $(MAKE) BUILD_IPSEC_MOD=$(BUILD_IPSEC_MOD) EXPORT=1 all
else
	cd $(NANOSEC_LINUX) && $(MAKE) BUILD_IPSEC_MOD=$(BUILD_IPSEC_MOD) all
endif
	cp $(NANOSEC_LINUX)/gpl/*.ko $(BIN_DIR)

ipsec_module_wrlinux:
	mkdir -p src/stage
	cp -rf src/examples/ipsec/linux/* src/stage/.
	cp src/stage/Makefile.wrlinux src/stage/Makefile
	cd src/stage && $(MAKE) -f Makefile.wrlinux links all

missiu:
	cd src/examples/ipsec/linux/missiu && $(MAKE) clean all
	cp src/examples/ipsec/linux/missiu/missiu $(BIN_DIR)

ipsec_loadconfig:
	cd $(NANOSEC_LOADCFG) && $(MAKE) \
			SRC_DIR=$(CURDIR)/src \
			EXTRA_CFLAGS="-I$(CURDIR)/$(NANOSEC_SRC) -I$(CURDIR)/$(NANOSEC_IPSEC)" \
			LINUX_GPL_PATH=$(CURDIR)/$(NANOSEC_LINUX)/gpl/ \
			MISSIU_PATH=$(CURDIR)/$(NANOSEC_LINUX)/missiu/ \
			clean all
	cp $(NANOSEC_LOADCFG)/loadConfig $(BIN_DIR)
	cp $(NANOSEC_LOADCFG)/sample_config $(BIN_DIR)

harness_module:
	cd src/harness && $(MAKE) all
	cp src/harness/*.ko $(BIN_DIR)

ids:
	$(MAKE) -C src/ids/testaux -f makefile_mca all
	$(MAKE) -C src/ids/testaux -f makefile_mld all
	cp src/ids/mca/mca src/ids/mca/tools/gcc-mca.sh \
		src/ids/mca/syscall_extract.rb \
		src/ids/testaux/mld $(BIN_DIR)

