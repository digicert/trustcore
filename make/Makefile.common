all: mss

rebuild: clean all

print-% : ; $(info $* is $(flavor $*) variable set to [$($*)]) @true

# Libraries definitions for targets
#
ifneq ($(HW_ACCEL_DEV),)
LIBS_MSSTCL   = -lmcommon -lmhwoffload -lmcrypto -lmharness \
		-lmplatform -lmcommon -ltcl
else
LIBS_MSSTCL   = -lmcrypto -lmcommon -lmplatform -lmcommon -lmcrypto -ltcl
endif


# $(MSS_OBJ): $(HEADERS)

crypto: $(CRYPTO_TARGET)
	$(LD) $(LIBS) -o $(BIN_DIR)$(SEP)$@$(OUT_EXT) $(CRYPTO_TARGET)

crypto_shared: $(CRYPTO_TARGET)
	$(CC) $(LIBS) -shared -o $(BIN_DIR)$(SEP)libcrypto.so $(CRYPTO_TARGET)

libnanocrypto: $(NCRYPTO_TARGET)
	$(AR) -r $(STATIC_BIN_DIR)$(SEP)libnanocrypto.a $(NCRYPTO_TARGET)

libnanocrypto_shared: $(NCRYPTO_TARGET)
	$(CC) -shared -o $(BIN_DIR)$(SEP)libnanocrypto.so $(NCRYPTO_TARGET)

libnanocrypto_example: libnanocrypto $(NCRYPTO_EXAMPLE_TARGET)
	$(LD) -o $(STATIC_BIN_DIR)$(SEP)nanocrypto_example$(OUT_EXT) $(NCRYPTO_EXAMPLE_TARGET) -L$(STATIC_BIN_DIR) -lnanocrypto $(LIBS)

libnanocrypto_example_shared: libnanocrypto_shared $(NCRYPTO_EXAMPLE_TARGET)
	$(LD) -o $(BIN_DIR)$(SEP)nanocrypto_example$(OUT_EXT) $(NCRYPTO_EXAMPLE_TARGET) -L$(BIN_DIR) -lnanocrypto $(LIBS)

tpm: $(TPM_TARGET)
	$(LD) $(LIBS) $(NANOTAP_LINKFLAGS) -L$(BIN_DIR) -o $(BIN_DIR)$(SEP)$@$(OUT_EXT) $(TPM_TARGET)

