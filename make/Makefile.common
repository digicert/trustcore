#Create static library
# libcryptowpa2 -- Crypto Library for wpa2
# libwpa2 -- Wifi functionality
.PHONY: wpa2lib

wpa2lib: $(LIB_DIR)$(SEP)libcryptowpa2.a $(LIB_DIR)$(SEP)libwpa2.a

$(LIB_DIR)$(SEP)libcryptowpa2.a: $(CRYPTO_TARGET_STATIC)
	ar rcs $@ $^
	ranlib $(LIB_DIR)$(SEP)libcryptowpa2.a

$(LIB_DIR)$(SEP)libwpa2.a: $(WPA_STATIC)
	ar rcs $@ $^
	ranlib $(LIB_DIR)$(SEP)libwpa2.a

wpa2: $(WPA2_TARGET)
	$(CC) $(CFLAGS) $(WPA2_TARGET) -lpthread -lrt -o $(BIN_DIR)$(SEP)$@$(OUT_EXT)

nanopnac: $(NANOPNAC_TARGET)
	$(CC) $(CFLAGS) $(NANOPNAC_TARGET) -lpthread -lrt -o $(BIN_DIR)$(SEP)$@$(OUT_EXT)

mss: $(MSS_TARGET)
	$(LD) $(LIBS) -o $(BIN_DIR)$(SEP)$@$(OUT_EXT) $(MSS_TARGET)



ifeq "${DEBUG}" "on"
CFLAGS += -D__ENABLE_ALL_DEBUGGING__
CFLAGS += -D__ENABLE_DIGICERT_DEBUG_CONSOLE__
CFLAGS += -D__DIGICERT_DUMP_CONSOLE_TO_STDOUT__
CFLAGS += -D__ENABLE_DIGICERT_DEBUG_MEMORY__
CFLAGS += -D__ENABLE_LOOKUP_TABLE__
endif


