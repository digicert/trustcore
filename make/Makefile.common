libsslc: $(SSLC_TARGET)
	${AR} -r $(BIN_DIR)$(SEP)libsslc.a ${SSLC_TARGET}

libnanossl: $(LIBSSL_TARGET)
#if tap and opensslhim is enabled
#if only opensslshim is enabled
#if only tap is enabled
ifneq (,$(findstring __ENABLE_DIGICERT_TAP__,$(CFLAGS)))
	$(CC) -shared -o $(BIN_DIR)$(SEP)libnanossl.so $(LIBSSL_TARGET) -L$(BIN_DIR) -lcryptointerface -lnanotap2 -lsmptpm2 -ltpm2 -lnanotap2_common -lnano_common -lnanocryptocore -lnanocryptossl
else ifneq (,$(findstring __ENABLE_DIGICERT_TAP_REMOTE__,$(CFLAGS)))
	$(CC) -shared -o $(BIN_DIR)$(SEP)libnanossl.so $(LIBSSL_TARGET) -L$(BIN_DIR) -lnanocryptocore -lnanocryptossl
else ifneq (,$(findstring __ENABLE_DIGICERT_OPENSSL_SHIM__,$(CFLAGS)))
	#tap is false and openssl_shim is true
	$(CC) -shared -o $(BIN_DIR)$(SEP)libnanossl.so $(LIBSSL_TARGET) -L$(BIN_DIR) -lnanocrypto
else ifneq (,$(findstring __ENABLE_DIGICERT_MBEDTLS_SHIM__,$(CFLAGS)))
	#tap is false and mbedtls_shim is true
	$(CC) -shared -o $(BIN_DIR)$(SEP)libnanossl.so $(LIBSSL_TARGET) -L$(BIN_DIR) -lnanocrypto
else #tap is false and opensslshim is false
	$(CC) -shared -o $(BIN_DIR)$(SEP)libnanossl.so $(LIBSSL_TARGET) -L$(BIN_DIR) -lnanocryptossl
endif

libnanossl_static: $(LIBSSL_TARGET)
	$(RM) $(STATIC_BIN_DIR)$(SEP)libnanossl.a
	${AR} -r $(STATIC_BIN_DIR)$(SEP)libnanossl.a ${LIBSSL_TARGET}

libnanocrypto_ssl: $(LIBCRYPTO_SSL_TARGET)
	$(CC) -shared -o $(BIN_DIR)$(SEP)libnanocryptossl.so $(LIBCRYPTO_SSL_TARGET) -lpthread

libnanocrypto_ssl_static: $(LIBCRYPTO_SSL_TARGET)
	$(RM) $(BIN_DIR)$(SEP)libnanocryptossl.a
	${AR} -r $(BIN_DIR)$(SEP)libnanocryptossl.a ${LIBCRYPTO_SSL_TARGET}

libnanossl_crypto_static: $(LIBSSL_CRYPTO_TARGET)
	$(RM) $(STATIC_BIN_DIR)$(SEP)libnanosslcrypto.a
	${AR} -r $(STATIC_BIN_DIR)$(SEP)libnanosslcrypto.a ${LIBSSL_CRYPTO_TARGET}

libopenssl_shim: $(LIBOPENSSL_SHIM_TARGET) libnanossl
ifneq (,$(findstring __ENABLE_DIGICERT_TAP__,$(CFLAGS)))
ifneq (,$(findstring __ENABLE_DIGICERT_TAP_EXTERN__,$(CFLAGS)))
	$(CC) -shared ${OPENSSL_SHIM_LD_OPTION} -o $(BIN_DIR)$(SEP)libopenssl_shim.so $(LIBOPENSSL_SHIM_TARGET) -L$(BIN_DIR) -lnanossl -lcrypto -lnanocrypto -ltap_extern -lcryptointerface -lnanotap2 -lsmptpm2 -ltpm2 -lnanotap2_common -lnano_common
else
	$(CC) -shared ${OPENSSL_SHIM_LD_OPTION} -o $(BIN_DIR)$(SEP)libopenssl_shim.so $(LIBOPENSSL_SHIM_TARGET) -L$(BIN_DIR) -lnanossl -lcrypto -lnanocrypto -lcryptointerface -lnanotap2 -lsmptpm2 -ltpm2 -lnanotap2_common -lnano_common
endif
else
	$(CC) -shared ${OPENSSL_SHIM_LD_OPTION} -o $(BIN_DIR)$(SEP)libopenssl_shim.so $(LIBOPENSSL_SHIM_TARGET) -L$(BIN_DIR) -lnanossl -lcrypto -lnanocrypto
endif

libmbedtls_shim: $(LIBMBEDTLS_SHIM_TARGET)
	$(CC) -shared -o $(BIN_DIR)$(SEP)libmbedtls_shim.so $(LIBMBEDTLS_SHIM_TARGET) -L$(BIN_DIR) -lnanocrypto -lnanossl -lpthread

libopenssl_shim_static: $(LIBOPENSSL_SHIM_TARGET)
	$(RM) $(STATIC_BIN_DIR)$(SEP)libopenssl_shim.a
	${AR} -r $(STATIC_BIN_DIR)$(SEP)libopenssl_shim.a ${LIBOPENSSL_SHIM_TARGET}

libmbedtls_shim_static: $(LIBMBEDTLS_SHIM_TARGET)
	$(RM) $(STATIC_BIN_DIR)$(SEP)libmbedtls_shim.a
	${AR} -r $(STATIC_BIN_DIR)$(SEP)libmbedtls_shim.a ${LIBMBEDTLS_SHIM_TARGET}

libtap_extern: $(LIBTAP_EXTERN_TARGET)
	$(CC) -shared -o $(BIN_DIR)$(SEP)libtap_extern.so $(LIBTAP_EXTERN_TARGET) -L$(BIN_DIR) -lnanocryptocore

libdtlss: $(DTLSS_TARGET)
	${AR} -r $(BIN_DIR)$(SEP)libdtlss.a ${DTLSS_TARGET}

libdtlsc: $(DTLSC_TARGET)
