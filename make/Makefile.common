ike: $(IKE_TARGET)
ifneq (,$(findstring __ENABLE_DIGICERT_TAP__,$(CFLAGS)))
ifneq (,$(findstring __ENABLE_DIGICERT_TAP_REMOTE__,$(CFLAGS)))
	$(LD) $(LIBS) -o $(BIN_DIR)$(SEP)$@$(OUT_EXT) $(IKE_TARGET) -lrt \
          -L$(BIN_DIR) -lcryptointerface -lnanotap2 -lsmptpm2 -ltpm2 -lnanotap2_common -lnanocryptossl -lnano_common -lnanotap2_clientcomm -lnanotap2_configparser -lnanossl
else
	$(LD) $(LIBS) -o $(BIN_DIR)$(SEP)$@$(OUT_EXT) $(IKE_TARGET) -lrt \
          -L$(BIN_DIR) -lcryptointerface -lnanotap2 -lsmptpm2 -ltpm2 -lnanotap2_common -lnanocryptocore -lnano_common
endif
else
	$(LD) $(LIBS) -o $(BIN_DIR)$(SEP)$@$(OUT_EXT) $(IKE_TARGET) -lrt
endif
ifneq ($(PLATFORM_TARGET_DIR),)
	cp $(BIN_DIR)$(SEP)$@$(OUT_EXT) "$(PLATFORM_TARGET_DIR)"
endif

