#
# common Makefile for mss builds
#

MB_BUILDMODE ?= ignore
#$(info MB_BUILDMODE in Makefile.common is $(flavor $MB_BUILDMODE) set to $(MB_BUILDMODE))

ifneq ($(MB_BUILDMODE),ignore)
ifeq ($(MB_BUILDMODE),optimized)
  CFLAGS += -g -O3
else
  ifeq ($(MB_BUILDMODE),o2)
    CFLAGS += -g -O2
  else
    ifeq ($(MB_BUILDMODE),os)
      CFLAGS += -Os
    else
      ifeq ($(MB_BUILDMODE),debug)
        CFLAGS += -g
      else
        ifeq ($(MB_BUILDMODE),osdebug)
          CFLAGS += -g -Os
        else
          CFLAGS += -g -O2
        endif
      endif
    endif
  endif
endif
endif

ifneq (${NO_TCP},)
  CFLAGS += -D__DISABLE_DIGICERT_TCP_INTERFACE__
endif

ifneq (${NO_UDP},)
  CFLAGS += -D__DISABLE_DIGICERT_UDP_INTERFACE__
endif

#
# Only allow AESNI build if enabled in the CFLAGS
ifneq (,$(findstring _ENABLE_DIGICERT_AES_NI_,${CFLAGS}))
  AESNI = 1
endif

ifneq (,$(findstring _ENABLE_DIGICERT_AES_NI_RUNTIME_CHECK_,$(CFLAGS)))
  AESNI = 1
endif
#
#

ifeq (_ENABLE_TAP_REMOTE_,$(findstring _ENABLE_TAP_REMOTE_,$(CFLAGS)))
  TAPREMOTE = 1
endif

ifeq (_ENABLE_DIGICERT_ECC_,$(findstring _ENABLE_DIGICERT_ECC_,$(CFLAGS)))
  SUITEB = 1
endif

ifeq (_ENABLE_DIGICERT_GCM_,$(findstring _ENABLE_DIGICERT_GCM_,$(CFLAGS)))
  SUITEB = 1
endif

ifeq (_ENABLE_DIGICERT_PQC_,$(findstring _ENABLE_DIGICERT_PQC_,$(CFLAGS)))
  SUITEB = 1
endif

ifeq (_ENABLE_DIGICERT_SMP_,$(findstring _ENABLE_DIGICERT_SMP_,$(CFLAGS)))
  SMP = 1
endif

ifeq "${MB_OS}" "osx"
  OPENSSL_SHIM_LD_OPTION=
else
ifneq (,$(findstring _ENABLE_DIGICERT_OPENSSL_LIB_1_1_0,$(CFLAGS)))
  OPENSSL_SHIM_LD_OPTION=-Wl,--version-script=$(OSSL_SRC_DIR)$(SEP)openssl-1.1.0.ld -Wl,-znodelete
else
  OPENSSL_SHIM_LD_OPTION=-Wl,--version-script=$(OSSL_SRC_DIR)$(SEP)openssl.ld
endif
endif

