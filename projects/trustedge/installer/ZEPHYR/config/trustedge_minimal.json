{
    "directory_paths": {
        "bin_dir": "/usr/bin",
        "lib_dir": "/usr/lib",
        "root_dir": "/etc/digicert",
        "conf_dir": "/etc/digicert/conf",
        "keystore_dir": "/etc/digicert/keystore"
    },
    "proxy": {
        "url": null
    },
    "agent": {
        "bootstrap": "/etc/digicert/conf/bootstrap_config.json",
        "workspace_dir": "/tmp",
        "connection_uptime_interval": 60,
        "keepalive_interval": 25,
        "recv_polling_interval": 2000,
        "sleep_interval": 30,
        "action_handler_timeout": 300,
        "enforce_token": false,
        "max_retry_count": 0,
        "log_payload": false,
        "protocol_buffer_size": 16384,
        "attributes_refresh_hours": 24,
        "renewal_hours": 720,
        "chunk_supported": false,
        "chunk_size": 512,
        "chunk_window_size": 4
    },
    "certificate": {
        "service_dir": "/etc/digicert/service",
        "polling_interval": 15,
        "renewal_hours": 360,
        "mode": "est"
    },
    "service": {
        "mode": "agent"
    },
    "api": {
        "mode": "http",
        "port": 8469,
        "num_process": 5,
        "num_resource": 5,
        "server_keycert_alias": "te-api-server",
        "server_hostname": "localhost"
    },
    "log": {
        "loglevel": "INFO"
    }
}
